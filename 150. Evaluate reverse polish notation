class Solution {
    public int evalRPN(String[] tokens) {
        Stack<Integer> st=new Stack<>();
        int n=tokens.length;
        for(int i=0;i<n;i++){
            if(tokens[i].equals("+")){
                int a=st.pop();
                st.push(st.pop()+a);
            }
            else if(tokens[i].equals("-")){
                int a=st.pop();
                st.push(st.pop()-a);
            }
            else if(tokens[i].equals("*")){
                int a=st.pop();
                st.push(st.pop()*a);
            }
            else if(tokens[i].equals("/")){
                int a=st.pop();
                st.push(st.pop()/a);
            }
            else{
                int a=Integer.valueOf(tokens[i]);
                st.push(a);
            }
        }
        return st.pop();
    }
}
