class Solution {
    static void reverse(int[] arr,int l,int r){
        while(l<r){
            int t=arr[l];
            arr[l]=arr[r];
            arr[r]=t;
            l++;
            r--;
        }
    }
    public void rotate(int[] nums, int k) {
        int n=nums.length;
        k=k%n;
        //for right rotation            //for left rotation
        reverse(nums,0,n-1);             //reverse(arr,0,s-1);
        reverse(nums,k,n-1);             //reverse(arr,s,n-1);
        reverse(nums,0,k-1);             //reverse(arr,0,n-1);
        System.out.print(Arrays.toString(nums));
    }
}
