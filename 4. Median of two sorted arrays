class Solution {
    public double findMedianSortedArrays(int[] nums1, int[] nums2) {
        int m=nums1.length;
        int n=nums2.length;
        int p=m+n;
        int[] arr=new int[p];
        for(int i=0;i<m;i++) arr[i]=nums1[i];
        for(int i=m;i<p;i++) arr[i]=nums2[i-m];
        Arrays.sort(arr);
        double ans;
        if(p%2!=0) ans=arr[p/2];
        else{
            ans=(double) (arr[(p/2)-1]+arr[p/2])/2;
        }
        return ans;
    }
}
