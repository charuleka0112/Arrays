class Solution {
    public int[] nextGreaterElements(int[] nums) {
        Stack<Integer> st=new Stack<>();
        int n=nums.length;
        int[] a=new int[n];
        Arrays.fill(a,-1);
        for(int i=0;i<n*2;i++){
            while(!st.isEmpty() && nums[i%n]>nums[st.peek()]){
                a[st.pop()]=nums[i%n];
            }
            st.push(i%n);
        }
        return a;
    }
}
